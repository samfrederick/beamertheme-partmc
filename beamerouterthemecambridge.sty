% 1. Define the base color (Deep Navy)

% Define the colors to match your screenshot
\setbeamercolor{author in head/foot}{bg=PartMCDarkBlue, fg=WarmCream}
\setbeamercolor{title in head/foot}{bg=PartMCLightBlue, fg=WarmCream}
\setbeamercolor{date in head/foot}{bg=PartMCLightOrange, fg=WarmCream}

\defbeamertemplate*{footline}{cambridge theme}
{
  % CRITICAL: \leavevmode must be active to prevent vertical stacking
  \leavevmode%
  \hbox{%
    \ifx\insertframetitle\@empty
      % --- TITLE SLIDE (Invisible Placeholder) ---
      % We draw empty boxes with the EXACT same dimensions as the real footer.
      % This forces Beamer to reserve space at the bottom, fixing the crop.
      \begin{beamercolorbox}[wd=.333333\paperwidth,ht=2.25ex,dp=1ex,center]{}%
      \end{beamercolorbox}%
      \begin{beamercolorbox}[wd=.333333\paperwidth,ht=2.25ex,dp=1ex,center]{}%
      \end{beamercolorbox}%
      \begin{beamercolorbox}[wd=.333333\paperwidth,ht=2.25ex,dp=1ex,right]{}%
      \end{beamercolorbox}%
    \else
      % --- NORMAL SLIDE (Visible Footer) ---
      \begin{beamercolorbox}[wd=.333333\paperwidth,ht=2.25ex,dp=1ex,center]{author in head/foot}%
        \usebeamerfont{author in head/foot}\insertshortauthor
      \end{beamercolorbox}%
      \begin{beamercolorbox}[wd=.333333\paperwidth,ht=2.25ex,dp=1ex,center]{title in head/foot}%
        \usebeamerfont{title in head/foot}\insertshorttitle
      \end{beamercolorbox}%
      \begin{beamercolorbox}[wd=.333333\paperwidth,ht=2.25ex,dp=1ex,right]{date in head/foot}%
        \usebeamerfont{date in head/foot}\insertshortdate{}\hspace*{2em}
        \insertframenumber{} / \inserttotalframenumber\hspace*{2ex} 
      \end{beamercolorbox}%
    \fi
  }%
  \vskip0pt%
}

